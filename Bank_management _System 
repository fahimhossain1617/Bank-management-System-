
#include <stdio.h>
#include <string.h>
int main()
{
// Variable Declaration
int choice, pin, enteredPin;
int attempts = 0, maxAttempts = 3;
int masterPin, unlockPin;
int newPin, confirmPin, i;
float balance = 1000.0f, amount;
char name[100];
char history[20][50];
float historyAmount[20];
int totalTransactions = 0;
int loggedIn = 0; // FIX: flag replaces goto
printf("WELCOME TO Prime Bank\n");
printf("Enter Your Full Name: "); scanf(" %[^\n]", name);
// Login PIN Setup
while (1)
{
printf("Set 4-Digit Login PIN: ");
scanf("%d", &pin);
if (pin >= 1000 && pin <= 9999)
break;
printf("Invalid PIN! Must be a 4-digit number.\n");
}
// Master PIN Setup
while (1)
{
printf("Set 4-Digit Master PIN (for account recovery): ");
scanf("%d", &masterPin);
if (masterPin < 1000 || masterPin > 9999)
printf("Invalid Master PIN! Must be a 4-digit number.\n");
else if (masterPin == pin)
printf("Master PIN cannot be the same as your Login PIN!\n");
else
break;
}
// FIX: Login system rewritten without goto, using loggedIn flag
while (!loggedIn)
{
attempts = 0; // FIX: reset attempts at the start of each login round
while (attempts < maxAttempts)
{
printf("\nEnter PIN to Login: ");
scanf("%d", &enteredPin);
if (enteredPin == pin)
{
printf("\nLogin Successful!\n");
loggedIn = 1;
break;
}
attempts++;
printf("Wrong PIN!\n");
if (attempts < maxAttempts)
printf("Remaining Attempts: %d\n", maxAttempts - attempts);
}
if (!loggedIn) // FIX: account lock only triggers if login failed
{
printf("\nAccount Locked!\n");
printf("Enter Your Master PIN: ");
scanf("%d", &unlockPin); if (unlockPin == masterPin)
{
printf("Account Unlocked Successfully!\n");
while (1)
{
printf("Set a New 4-Digit Login PIN: ");
scanf("%d", &newPin);
if (newPin < 1000 || newPin > 9999)
printf("Invalid PIN! Must be a 4-digit number.\n");
else if (newPin == masterPin)
printf("New PIN cannot be the same as Master PIN!\n"); // FIX: added check
else
{
pin = newPin;
printf("PIN Reset Successful! Logging in...\n");
loggedIn = 1; // FIX: auto-login after verified recovery
break;
}
}
}
else
{
printf("Wrong Master PIN! Program Terminated.\n");
return 0;
}
}
}
// FIX: This runs exactly ONCE after login, never duplicated
strcpy(history[totalTransactions], "Account Opened");
historyAmount[totalTransactions] = balance;
totalTransactions++;
// Main Menu
do
{
printf("\nMAIN MENU\n");
printf("1. Check Balance\n");
printf("2. Deposit Money\n");
printf("3. Withdraw Money\n");
printf("4. Transaction History\n");
printf("5. Change PIN\n");
printf("6. Exit\n");
printf("Enter Choice: ");
scanf("%d", &choice);
switch (choice)
{
case 1: // Check Balance printf("\nName : %s\n", name);
printf("Balance : %.2f BDT\n", balance);
break;
case 2: // Deposit Money
printf("Enter Deposit Amount: ");
scanf("%f", &amount);
if (amount <= 0)
printf("Invalid Amount!\n");
else if (totalTransactions >= 20) // FIX: buffer overflow guard
printf("Transaction limit reached! Cannot record more transactions.\n");
else
{
balance += amount;
strcpy(history[totalTransactions], "Deposited");
historyAmount[totalTransactions] = amount;
totalTransactions++;
printf("Deposit Successful! New Balance: %.2f BDT\n", balance);
}
break;
case 3: // Withdraw Money
printf("Enter Withdraw Amount: ");
scanf("%f", &amount);
if (amount <= 0)
printf("Invalid Amount!\n");
else if (amount > balance)
printf("Insufficient Balance!\n");
else if (totalTransactions >= 20) // FIX: buffer overflow guard
printf("Transaction limit reached! Cannot record more transactions.\n");
else
{
balance -= amount;
strcpy(history[totalTransactions], "Withdrawn");
historyAmount[totalTransactions] = amount;
totalTransactions++;
printf("Withdraw Successful! New Balance: %.2f BDT\n", balance);
}
break;
case 4: // Transaction History
printf("\n TRANSACTION HISTORY \n");
for (i = 0; i < totalTransactions; i++)
{
printf("%d. %-15s --> %.2f BDT\n", i + 1, history[i], historyAmount[i]);
}
printf("Current Balance: %.2f BDT\n", balance);
break;
case 5: // Change PIN
printf("Enter Current PIN: "); scanf("%d", &enteredPin);
if (enteredPin != pin)
{
printf("Wrong PIN!\n");
}
else
{
while (1) // FIX: loop until valid new PIN is entered
{
printf("Enter New PIN: ");
scanf("%d", &newPin);
printf("Confirm New PIN: ");
scanf("%d", &confirmPin);
if (newPin < 1000 || newPin > 9999)
printf("Invalid PIN! Must be a 4-digit number.\n");
else if (newPin != confirmPin)
printf("PINs do not match! Try again.\n"); // FIX: specific error
else if (newPin == masterPin)
printf("New PIN cannot be the same as Master PIN!\n"); // FIX: added check
else if (newPin == pin)
printf("New PIN must be different from current PIN!\n");
else
{
pin = newPin;
printf("PIN Changed Successfully!\n");
break;
}
}
}
break;
case 6: // Exit
printf("\nThank You, %s!\n", name);
printf("Goodbye!\n");
break;
default: // Invalid Choice
printf("Invalid Choice! Please enter 1-6.\n");
}
} while (choice != 6);
return 0;
}